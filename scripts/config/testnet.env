# =============================================================================
# ChainBridge Testnet Configuration
# =============================================================================
# Copy this file to scripts/config/testnet.env.local and fill in real values.
# Never commit secrets to version control.
# =============================================================================

# Stellar network identifier
STELLAR_NETWORK=testnet

# Soroban/Horizon RPC endpoints
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deployer account - source account for all transactions
# Fund this address on testnet: https://friendbot.stellar.org/?addr=<ADDRESS>
DEPLOYER_SECRET_KEY=

# Admin address that will be set as contract admin on init.
# Set to the deployer address or a separate multisig address.
ADMIN_ADDRESS=

# Optional: path to an existing WASM file to skip re-building.
# Leave empty to build from source.
CONTRACT_WASM_PATH=

# Ledger sequence bump applied to persistent storage entries on deploy.
STORAGE_LEDGER_BUMP=1000000
